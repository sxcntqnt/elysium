# Copy to .env for local development. Never commit this file.

# ── Vault bootstrap (required — unlocks everything else) ─────────────────────
# Generate a dev token: vault token create -policy=auth-service
VAULT_ADDR=http://127.0.0.1:8200
VAULT_ROLE_ID=                      # from: vault read auth/approle/role/auth-service/role-id
VAULT_SECRET_ID=                    # from: vault write -f auth/approle/role/auth-service/secret-id
VAULT_NAMESPACE=                    # optional; leave empty for root namespace
VAULT_KV_MOUNT=secret
VAULT_KV_PREFIX=auth-service

# ── Vault KV v2 secrets (written once; loaded by the service at startup) ─────
# vault kv put secret/auth-service/jwt \
#   signing_key="$(openssl rand -hex 32)" \
#   access_ttl=15m \
#   refresh_ttl=168h
#
# vault kv put secret/auth-service/bcrypt cost=12
#
# vault kv put secret/auth-service/database \
#   dgraph_target=localhost:9080 \
#   tls_enabled=false

# ── Signer mode ───────────────────────────────────────────────────────────────
# true  = Vault Transit (key never leaves Vault; requires Transit engine mount)
# false = HMAC with key from KV v2 (simpler; use for local dev)
AUTH_USE_TRANSIT=false
AUTH_TRANSIT_MOUNT=transit
AUTH_TRANSIT_KEY=auth-service-jwt

# ── Server (non-sensitive) ────────────────────────────────────────────────────
AUTH_HTTP_ADDR=:8080
AUTH_GRPC_ADDR=:9090
AUTH_SHUTDOWN_TIMEOUT=30s
AUTH_ENV=development
AUTH_LOG_LEVEL=debug
AUTH_ISSUER=auth-service

# ── Rate limiting ─────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT_RPS=10
AUTH_RATE_LIMIT_BURST=30

# ── Dgraph ────────────────────────────────────────────────────────────────────
DGRAPH_APPLY_SCHEMA=true
